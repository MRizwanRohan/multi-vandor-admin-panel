          "request_body": "Same as store, all fields optional",
          "response": {
            "data": "updated Banner object"
          }
        },
        {
          "method": "DELETE",
          "path": "/{id}",
          "action": "destroy",
          "description": "Delete a banner"
        },
        {
          "method": "PUT",
          "path": "/{id}/toggle",
          "action": "toggle",
          "description": "Toggle banner active status"
        },
        {
          "method": "PUT",
          "path": "/{id}/move-up",
          "action": "moveUp",
          "description": "Move banner up in display order"
        },
        {
          "method": "PUT",
          "path": "/{id}/move-down",
          "action": "moveDown",
          "description": "Move banner down in display order"
        }
      ]
    },
    
    "public_routes": {
      "prefix": "/banners",
      "middleware": ["throttle:public"],
      "endpoints": [
        {
          "method": "GET",
          "path": "/",
          "action": "index",
          "description": "Get active banners (optionally filtered by position)",
          "query_params": {
            "position": "string - if provided, filter by position; otherwise returns grouped by position"
          },
          "response": {
            "data": "array of active Banner objects or grouped by position"
          }
        },
        {
          "method": "GET",
          "path": "/hero",
          "action": "hero",
          "description": "Get homepage hero banners"
        },
        {
          "method": "GET",
          "path": "/positions",
          "action": "positions",
          "description": "Get available positions"
        },
        {
          "method": "GET",
          "path": "/position/{position}",
          "action": "byPosition",
          "description": "Get active banners for a specific position"
        }
      ]
    }
  },

  "newsletter": {
    "overview": {
      "description": "Newsletter subscription management with email verification",
      "service": "App\\Services\\Marketing\\NewsletterService",
      "model": "App\\Models\\NewsletterSubscriber"
    },
    
    "database": {
      "table": "newsletter_subscribers",
      "columns": {
        "id": "bigint unsigned, primary key",
        "email": "string, unique - subscriber email",
        "name": "string, nullable - subscriber name",
        "source": "string(50), default 'website' - subscription source",
        "verification_token": "string(100), nullable - email verification token",
        "unsubscribe_token": "string(100), nullable - one-click unsubscribe token",
        "verified_at": "timestamp, nullable - when email was verified",
        "subscribed_at": "timestamp, nullable - initial subscription date",
        "unsubscribed_at": "timestamp, nullable - when unsubscribed",
        "resubscribed_at": "timestamp, nullable - when resubscribed",
        "is_active": "boolean, default false - active subscription status",
        "created_at": "timestamp",
        "updated_at": "timestamp"
      },
      "indexes": ["email", "is_active", "source", "verification_token", "unsubscribe_token"]
    },
    
    "subscription_sources": {
      "values": ["website", "checkout", "popup", "import", "admin"],
      "note": "Custom sources can be added"
    },
    
    "admin_routes": {
      "prefix": "/admin/newsletter",
      "middleware": ["auth:sanctum", "role:admin,super_admin", "throttle:admin"],
      "endpoints": [
        {
          "method": "GET",
          "path": "/subscribers",
          "action": "index",
          "description": "List all subscribers with filters",
          "query_params": {
            "status": "string (active|inactive|verified|unverified)",
            "source": "string - filter by subscription source",
            "search": "string - search in email or name",
            "subscribed_from": "date",
            "subscribed_to": "date",
            "sort_by": "string (default: subscribed_at)",
            "sort_direction": "string (default: desc)",
            "per_page": "integer (default: 15)"
          },
          "response": {
            "type": "paginated",
            "data": "array of NewsletterSubscriber objects"
          }
        },
        {
          "method": "GET",
          "path": "/stats",
          "action": "stats",
          "description": "Get newsletter statistics",
          "response": {
            "data": {
              "total_subscribers": "integer",
              "active_subscribers": "integer",
              "verified_subscribers": "integer",
              "unverified": "integer",
              "unsubscribed": "integer",
              "this_month": "integer - new subscribers this month",
              "growth_rate": "decimal - month-over-month growth %",
              "by_source": "object - counts per source",
              "recent_subscribers": "array of 5 most recent subscribers"
            }
          }
        },
        {
          "method": "GET",
          "path": "/export",
          "action": "export",
          "description": "Export subscribers to CSV",
          "query_params": {
            "status": "string - filter by status",
            "source": "string - filter by source"
          },
          "response": {
            "content_type": "text/csv",
            "columns": ["Email", "Name", "Subscribed At", "Source"]
          }
        },
        {
          "method": "POST",
          "path": "/import",
          "action": "import",
          "description": "Import subscribers from CSV",
          "content_type": "multipart/form-data",
          "request_body": {
            "file": "required|file|mimes:csv,txt|max:5120"
          },
          "csv_format": {
            "columns": ["email (required)", "name (optional)"]
          },
          "response": {
            "data": {
              "imported_count": "integer",
              "skipped_count": "integer",
              "errors": "array of error messages"
            }
          }
        },
        {
          "method": "DELETE",
          "path": "/subscribers/bulk",
          "action": "bulkDelete",
          "description": "Bulk delete subscribers",
          "request_body": {
            "subscriber_ids": "required|array|min:1"
          }
        },
        {
          "method": "PUT",
          "path": "/subscribers/bulk-unsubscribe",
          "action": "bulkUnsubscribe",
          "description": "Bulk unsubscribe subscribers",
          "request_body": {
            "subscriber_ids": "required|array|min:1"
          }
        },
        {
          "method": "GET",
          "path": "/subscribers/{id}",
          "action": "show",
          "description": "Get subscriber details"
        },
        {
          "method": "POST",
          "path": "/subscribers",
          "action": "store",
          "description": "Add subscriber manually (admin)",
          "request_body": {
            "email": "required|email|unique:newsletter_subscribers,email",
            "name": "nullable|string|max:255",
            "skip_verification": "boolean (default: true for admin)"
          }
        },
        {
          "method": "PUT",
          "path": "/subscribers/{id}",
          "action": "update",
          "description": "Update subscriber details",
          "request_body": {
            "name": "nullable|string|max:255",
            "is_active": "boolean"
          }
        },
        {
          "method": "DELETE",
          "path": "/subscribers/{id}",
          "action": "destroy",
          "description": "Delete a subscriber"
        },
        {
          "method": "PUT",
          "path": "/subscribers/{id}/unsubscribe",
          "action": "adminUnsubscribe",
          "description": "Unsubscribe a subscriber by admin"
        },
        {
          "method": "PUT",
          "path": "/subscribers/{id}/resubscribe",
          "action": "resubscribe",
          "description": "Resubscribe an unsubscribed user"
        },
        {
          "method": "POST",
          "path": "/subscribers/{id}/resend-verification",
          "action": "resendVerification",
          "description": "Resend verification email to unverified subscriber"
        }
      ]
    },
    
    "public_routes": {
      "prefix": "/newsletter",
      "middleware": ["throttle:public"],
      "endpoints": [
        {
          "method": "POST",
          "path": "/subscribe",
          "action": "subscribe",
          "description": "Subscribe to newsletter",
          "request_body": {
            "email": "required|email|max:255",
            "name": "nullable|string|max:255"
          },
          "headers": {
            "X-Source": "optional - subscription source"
          },
          "response": {
            "success": {
              "subscribed": true,
              "verification_required": "boolean - true if email verification needed"
            },
            "already_subscribed": {
              "already_subscribed": true
            }
          }
        },
        {
          "method": "GET",
          "path": "/verify/{token}",
          "action": "verify",
          "description": "Verify email subscription",
          "params": {
            "token": "string - verification token"
          },
          "response": {
            "data": {
              "verified": true
            }
          }
        },
        {
          "method": "POST",
          "path": "/unsubscribe",
          "action": "unsubscribe",
          "description": "Unsubscribe from newsletter",
          "request_body": {
            "email": "required_without:token|email",
            "token": "required_without:email|string"
          },
          "response": {
            "data": {
              "unsubscribed": true
            }
          }
        },
        {
          "method": "GET",
          "path": "/unsubscribe/{token}",
          "action": "unsubscribeByToken",
          "description": "One-click unsubscribe via email link",
          "params": {
            "token": "string - unsubscribe token"
          }
        },
        {
          "method": "GET",
          "path": "/status",
          "action": "status",
          "description": "Check subscription status",
          "query_params": {
            "email": "required|email"
          },
          "response": {
            "data": {
              "is_subscribed": "boolean",
              "is_verified": "boolean"
            }
          }
        }
      ]
    },
    
    "subscription_flow": {
      "steps": [
        "1. User submits email via /subscribe",
        "2. System creates subscriber with verification_token",
        "3. Verification email sent with link to /verify/{token}",
        "4. User clicks link, email verified, is_active = true",
        "5. Unsubscribe via token or email using /unsubscribe"
      ],
      "admin_override": "Admin can add subscribers with skip_verification=true"
    }
  },

  "common_response_formats": {
    "success_response": {
      "success": true,
      "message": "string",
      "data": "mixed"
    },
    "error_response": {
      "success": false,
      "message": "string",
      "errors": "object (validation errors)"
    },
    "paginated_response": {
      "success": true,
      "message": "string",
      "data": "array",
      "meta": {
        "current_page": "integer",
        "from": "integer",
        "last_page": "integer",
        "links": "array",
        "path": "string",
        "per_page": "integer",
        "to": "integer",
        "total": "integer"
      },
      "links": {
        "first": "string",
        "last": "string",
        "prev": "string or null",
        "next": "string or null"
      }
    }
  },

  "caching": {
    "coupon_cache": {
      "prefix": "coupon:",
      "ttl": 3600,
      "keys": ["code:{code}", "admin_stats"]
    },
    "flash_sale_cache": {
      "prefix": "flash_sale:",
      "ttl": 300,
      "keys": ["active", "upcoming", "admin_stats"]
    },
    "banner_cache": {
      "prefix": "banner:",
      "ttl": 3600,
      "keys": ["position:{position}", "all_active", "stats"]
    },
    "newsletter_cache": {
      "prefix": "newsletter:",
      "ttl": 3600,
      "keys": ["stats"]
    }
  },

